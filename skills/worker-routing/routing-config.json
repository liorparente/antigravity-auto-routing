    "^\\s*grep(?:\\s+-[a-zA-Z0-9]+)?(?:\\s+[^>|&;]+)?\\s*$",
    "^\\s*rg(?:\\s+-[a-zA-Z0-9]+)?(?:\\s+[^>|&;]+)?\\s*$",
    "^\\s*git\\s+(?:status|log|diff|show|branch)(?:\\s+[^>|&;]+)?\\s*$",
    "^\\s*curl\\s+-[a-zA-Z]+(?:\\s+[^>|&;]+)?\\s*$",
    "^\\s*jq\\s+[^>|&;]*$",
    "^\\s*which\\s+[^>|&;]+\\s*$",
    "^\\s*echo\\s+[^>|&;]*$",
    "^\\s*pwd\\s*$",
    "^\\s*find\\s+[^>|&;]*$",
    "^\\s*python3\\s+-m\\s+unittest(?:\\s+[^>|&;]+)?\\s*$",
    "^\\s*lsof(?:\\s+-[a-zA-Z0-9:]+)?(?:\\s+[^>|&;]+)?\\s*$"
